# Nexora Uptime Monitor - Environment Configuration

# PORT for the web server (default: 3015)
# PORT=3015

# Node environment (production or development)
# NODE_ENV=production

# Discord Bot Configuration
# DISCORD_BOT_TOKEN=your_bot_token_here
# DISCORD_CHANNEL_ID=your_channel_id_here

# Admin Panel Security
# ADMIN_PASSWORD=your_secure_password_here

# TOTP (Two-Factor Authentication) - Optional
# TOTP_SECRET=your_totp_secret_here

# Everything that's up is managed by the server on the admin endpoint, no need to worry unless you want to set them up manually.

# Logging Configuration
# Set to "true" to save logs to terminal.log file, "false" to disable file logging
SAVE_LOGS=true
